/// Plant dimension. One row per manufacturing line.
table dim_plant
	lineageTag: 9eaee8ee-2ff6-4b33-8a5c-d73e4adbd4dd

	/// Surrogate key for plant x line.
	column plant_line_key
		dataType: int64
		isHidden
		isKey
		summarizeBy: none
		sourceColumn: plant_line_key
		lineageTag: fcd112a7-529e-4dad-83b0-3a900d718a33

	/// Anonymized plant label (Plant_A..Plant_D). Never real plant names.
	column plant_name
		dataType: string
		summarizeBy: none
		sourceColumn: plant_name
		lineageTag: 19599988-49b0-4b1f-950f-4f13ae5f7b58

	/// Production line label (Line_01..Line_03).
	column line_name
		dataType: string
		summarizeBy: none
		sourceColumn: line_name
		lineageTag: f1204e2c-1f9d-41a0-a4c0-e3fd5878f0fa

	partition dim_plant = entity
		mode: directLake
		source
			entityName: dim_plant
			schemaName: dbo
			expressionSource: DatabaseQuery

